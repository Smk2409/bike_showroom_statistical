





<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Speed Wheels | Premium Bike Showroom</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<link rel="stylesheet"
href="{{ url_for('static', filename='css/style.css') }}">

</head>

<body>

<!-- ================= NAVBAR ================= -->

<nav class="navbar navbar-expand-lg fixed-top glass">

<div class="container">

<a class="navbar-brand logo" href="#">

<i class="fa-solid fa-motorcycle"></i>

Speed Wheels

</a>

<button class="navbar-toggler"
data-bs-toggle="collapse"
data-bs-target="#menu">

<span class="navbar-toggler-icon"></span>

</button>

<div class="collapse navbar-collapse"
id="menu">

<ul class="navbar-nav ms-auto">

<li class="nav-item">

<a class="nav-link active" href="#">
Home
</a>

</li>

<li class="nav-item">

<a class="nav-link" href="#">
Bikes
</a>

</li>

<li class="nav-item">

<a class="nav-link" href="#">
Offers
</a>

</li>

<li class="nav-item">

<a class="nav-link" href="#">
Accessories
</a>

</li>

<li class="nav-item">

<a class="nav-link" href="#">
Finance
</a>

</li>

<li class="nav-item">

<a class="nav-link" href="#">
Contact
</a>

</li>

</ul>

</div>

</div>

</nav>

<!-- ================= HERO ================= -->

<section class="hero">

<div class="container">

<div class="row align-items-center">

<div class="col-lg-6">

<h5 class="offer-tag">

🔥 Mega Sale 2026

</h5>

<h1>

Ride Beyond

<span>Limits</span>

</h1>

<p>

Explore premium motorcycles from
Royal Enfield,
BMW,
KTM,
Yamaha,
Honda,
Kawasaki and Ducati.

</p>

<div class="hero-buttons">

<button class="btn btn-danger btn-lg">

Book Test Ride

</button>

<button class="btn btn-outline-light btn-lg">

Explore Bikes

</button>

</div>

<div class="search-box">

<input
type="text"
placeholder="Search your dream bike...">

<button>

<i class="fa fa-search"></i>

</button>

</div>

</div>

<div class="col-lg-6 text-center">

<img
class="hero-bike"
src="https://images.unsplash.com/photo-1558981806-ec527fa84c39?auto=format&fit=crop&w=1000&q=80">

</div>

</div>

</div>

</section>

<!-- ================= OFFER ================= -->

<section class="coupon-section">

<div class="container">

<div class="coupon-card">

<div>

<h2>

🎁 Flat ₹20,000 OFF

</h2>

<p>

Applicable on selected premium bikes

</p>

</div>

<button>

Claim Coupon

</button>

</div>

</div>

</section>

<!-- ================= FEATURED ================= -->

<section class="featured">

<div class="container">

<div class="title">

<h2>

Featured Bikes

</h2>

<p>

Top Selling Bikes

</p>

</div>

<div class="row">

{% for bike in bikes %}

<div class="col-lg-4 col-md-6 mb-4">

<div class="bike-card">

<div class="discount">

10% OFF

</div>

<img
src="{{ bike.image }}">

<div class="bike-info">

<h3>

{{ bike.name }}

</h3>

<div class="rating">

★★★★★

</div>

<h4>

{{ bike.price }}

</h4>

<p>

{{ bike.color }}

</p>

<div class="buttons">

<button class="buy">

Buy Now

</button>

<button class="wish">

<i class="fa fa-heart"></i>

</button>

</div>

</div>

</div>

</div>

{% endfor %}

</div>

</div>

</section>

<!-- ================= STATS ================= -->

<section class="stats">

<div class="container">

<div class="row text-center">

<div class="col-md-3">

<h2>

1500+

</h2>

<p>

Happy Customers

</p>

</div>

<div class="col-md-3">

<h2>

120+

</h2>

<p>

Premium Bikes

</p>

</div>

<div class="col-md-3">

<h2>

45+

</h2>

<p>

Brands

</p>

</div>

<div class="col-md-3">

<h2>

12

</h2>

<p>

Years Experience

</p>

</div>

</div>

</div>

</section>

<!-- Remaining sections continue in Part 2 -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>
<!-- ================= OFFERS ================= -->

<section class="offers py-5">

<div class="container">

<div class="text-center mb-5">

<h1 class="display-5 fw-bold text-white">
🔥 Exclusive Offers
</h1>

<p class="text-light">
Grab exciting discounts before they expire!
</p>

</div>

<div class="row">

{% for offer in offers %}

<div class="col-lg-4 mb-4">

<div class="offer-card">

<h2>{{ offer.title }}</h2>

<p>{{ offer.description }}</p>

<button class="btn btn-warning">
Claim Offer
</button>

</div>

</div>

{% endfor %}

</div>

</div>

</section>

<!-- ================= BRANDS ================= -->

<section class="brands py-5">

<div class="container text-center">

<h2 class="mb-5 text-white">
Top Brands
</h2>

<div class="row">

<div class="col">
<img src="https://cdn.simpleicons.org/yamaha" height="70">
</div>

<div class="col">
<img src="https://cdn.simpleicons.org/bmw" height="70">
</div>

<div class="col">
<img src="https://cdn.simpleicons.org/honda" height="70">
</div>

<div class="col">
<img src="https://cdn.simpleicons.org/kawasaki" height="70">
</div>

<div class="col">
<img src="https://cdn.simpleicons.org/ktm" height="70">
</div>

</div>

</div>

</section>

<!-- ================= TESTIMONIAL ================= -->

<section class="testimonial py-5">

<div class="container">

<h1 class="text-center text-white mb-5">

What Customers Say

</h1>

<div class="row">

<div class="col-lg-4">

<div class="review-card">

<img src="https://randomuser.me/api/portraits/men/22.jpg">

<h3>Rahul Kumar</h3>

<p>

★★★★★

</p>

<p>

Amazing showroom.
Fast delivery and best price.

</p>

</div>

</div>

<div class="col-lg-4">

<div class="review-card">

<img src="https://randomuser.me/api/portraits/women/65.jpg">

<h3>Priya</h3>

<p>

★★★★★

</p>

<p>

Excellent customer support.
Loved my BMW G310R.

</p>

</div>

</div>

<div class="col-lg-4">

<div class="review-card">

<img src="https://randomuser.me/api/portraits/men/52.jpg">

<h3>Arun</h3>

<p>

★★★★★

</p>

<p>

Finance approval in just 30 minutes.

</p>

</div>

</div>

</div>

</div>

</section>

<!-- ================= CONTACT ================= -->

<section class="contact py-5">

<div class="container">

<div class="row">

<div class="col-lg-6">

<h2 class="text-white">

Contact Us

</h2>

<p class="text-light">

📍 Chennai, Tamil Nadu

</p>

<p class="text-light">

📞 +91 9876543210

</p>

<p class="text-light">

✉ speedwheels@gmail.com

</p>

</div>

<div class="col-lg-6">

<form>

<input
class="form-control mb-3"
placeholder="Your Name">

<input
class="form-control mb-3"
placeholder="Email">

<textarea
class="form-control mb-3"
rows="5"
placeholder="Message"></textarea>

<button
class="btn btn-danger">

Send Message

</button>

</form>

</div>

</div>

</div>

</section>

<!-- ================= NEWSLETTER ================= -->

<section class="newsletter py-5">

<div class="container text-center">

<h2 class="text-white">

Subscribe For Latest Offers

</h2>

<div class="row justify-content-center mt-4">

<div class="col-lg-6">

<div class="input-group">

<input
type="email"
class="form-control"
placeholder="Enter Email">

<button
class="btn btn-warning">

Subscribe

</button>

</div>

</div>

</div>

</div>

</section>

<!-- ================= FOOTER ================= -->

<footer class="footer">

<div class="container">

<div class="row">

<div class="col-lg-4">

<h3>

🏍 Speed Wheels

</h3>

<p>

India's Premium Bike Destination

</p>

</div>

<div class="col-lg-4">

<h5>

Quick Links

</h5>

<ul class="list-unstyled">

<li><a href="#">Home</a></li>

<li><a href="#">Bikes</a></li>

<li><a href="#">Offers</a></li>

<li><a href="#">Finance</a></li>

<li><a href="#">Contact</a></li>

</ul>

</div>

<div class="col-lg-4">

<h5>

Follow Us

</h5>

<i class="fab fa-facebook fa-2x me-3"></i>

<i class="fab fa-instagram fa-2x me-3"></i>

<i class="fab fa-youtube fa-2x me-3"></i>

<i class="fab fa-linkedin fa-2x"></i>

</div>

</div>

<hr>

<div class="text-center">

© 2026 Speed Wheels Bike Showroom

</div>

</div>

</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>